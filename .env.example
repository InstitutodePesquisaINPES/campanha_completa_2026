# ============================================================
# CAMPANHA ELEITORAL — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# ─── FRONTEND (Vite) ─────────────────────────────────────────
# URL da API backend (sem barra final)
VITE_API_URL=http://localhost:3001

# ─── SUPABASE (temporário — será removido na Fase 6) ────────
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ─── BACKEND API (NestJS) ───────────────────────────────────
NODE_ENV=development
API_PORT=3001

# JWT
JWT_SECRET=gere-com-openssl-rand-hex-64
JWT_REFRESH_SECRET=gere-com-openssl-rand-hex-64
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── POSTGRESQL ──────────────────────────────────────────────
PG_PASSWORD=gere-senha-forte
DATABASE_URL=postgresql://campanha:${PG_PASSWORD}@localhost:5432/campanha

# ─── REDIS ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CLICKHOUSE ──────────────────────────────────────────────
CH_PASSWORD=gere-senha-forte
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=eleicoes
CLICKHOUSE_USER=campanha

# ─── MINIO (S3 compatível) ──────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=gere-access-key
MINIO_SECRET_KEY=gere-secret-key
MINIO_USE_SSL=false

# ─── METABASE ────────────────────────────────────────────────
MB_PG_PASSWORD=gere-senha-forte
MB_READER_PASSWORD=gere-senha-forte

# ─── WORKER TSE ──────────────────────────────────────────────
# Configurações do worker Python de ETL do TSE
TSE_WORKER_POLL_INTERVAL=10
TSE_WORKER_BATCH_SIZE=10000
